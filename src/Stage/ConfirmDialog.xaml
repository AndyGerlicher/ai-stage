<Window x:Class="Stage.ConfirmDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Stage"
        Width="520" Height="360"
        MinWidth="400" MinHeight="260"
        Background="#1e1e1e"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        WindowStyle="None"
        AllowsTransparency="False"
        KeyDown="OnKeyDown">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome
            CaptionHeight="32"
            GlassFrameThickness="0"
            CornerRadius="0"
            ResizeBorderThickness="6"
            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <Style x:Key="DialogCloseButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#999"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="Transparent">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#e81123"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title bar -->
        <Border Grid.Row="0" Background="#252525">
            <DockPanel>
                <Button Content="&#xE8BB;" DockPanel.Dock="Right" Click="OnCancelClick"
                        Style="{StaticResource DialogCloseButtonStyle}"
                        shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
                <TextBlock x:Name="TitleText" Text="Confirm" Foreground="#888"
                           FontSize="12" FontFamily="Segoe UI"
                           VerticalAlignment="Center" Margin="14,0,0,0"/>
            </DockPanel>
        </Border>

        <!-- Body -->
        <DockPanel Grid.Row="1" Margin="20,16,20,0">
            <TextBlock x:Name="MessageText" DockPanel.Dock="Top"
                       Text="" Foreground="#ccc" FontSize="12" FontFamily="Segoe UI"
                       TextWrapping="Wrap" Margin="0,0,0,12"/>

            <Border Background="#2a2a2a" BorderBrush="#444" BorderThickness="1"
                    CornerRadius="2" Padding="10,8">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                              MaxHeight="200">
                    <TextBlock x:Name="DetailText" Text="" Foreground="#9cdcfe"
                               FontSize="11" FontFamily="Consolas"
                               TextWrapping="NoWrap"/>
                </ScrollViewer>
            </Border>
        </DockPanel>

        <!-- Footer -->
        <Border Grid.Row="2" Background="#252525" Padding="20,10">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Content="Cancel" Click="OnCancelClick"
                            Background="#333" Foreground="#ccc" BorderThickness="0"
                            Padding="16,6" FontSize="12" FontFamily="Segoe UI"
                            Cursor="Hand" Margin="0,0,8,0"/>
                    <Button x:Name="ConfirmButton" Content="Continue" Click="OnConfirmClick"
                            Background="#d4000e" Foreground="White" BorderThickness="0"
                            Padding="16,6" FontSize="12" FontFamily="Segoe UI Semibold"
                            Cursor="Hand"/>
                </StackPanel>
                <TextBlock Text="Esc to cancel" Foreground="#555"
                           FontSize="11" FontFamily="Segoe UI" VerticalAlignment="Center"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
