<Window x:Class="AiStage.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:conv="clr-namespace:AiStage.Converters"
        xmlns:models="clr-namespace:AiStage.Models"
        Title="ai-stage"
        MinWidth="500" MinHeight="300"
        Background="#1e1e1e"
        WindowStyle="None"
        AllowsTransparency="False"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterScreen"
        Loaded="OnLoaded"
        KeyDown="OnKeyDown">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome
            CaptionHeight="32"
            GlassFrameThickness="0"
            CornerRadius="0"
            ResizeBorderThickness="6"
            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <conv:RelativeTimeConverter x:Key="RelativeTime"/>
        <conv:AgentStateBrushConverter x:Key="AgentBrush"/>
        <conv:AgentStateGlyphConverter x:Key="AgentGlyph"/>
        <conv:GreaterThanOneToVisibilityConverter x:Key="GtOneToVis"/>

        <!-- Caption button (minimize / maximize / close / toolbar icons) -->
        <Style x:Key="CaptionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#999"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#383838"/>
                                <Setter Property="Foreground" Value="#ddd"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Close button (red on hover) -->
        <Style x:Key="CloseButtonStyle" TargetType="Button" BasedOn="{StaticResource CaptionButtonStyle}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="Transparent">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#e81123"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Row action button (small icon on repo/worktree rows) -->
        <Style x:Key="RowActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#aaa"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="2,0,0,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#383838"/>
                                <Setter Property="Foreground" Value="#fff"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- TreeViewItem: dark theme, flat, no default expander chrome disaster -->
        <Style x:Key="StageTreeViewItemStyle" TargetType="TreeViewItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#e8e8e8"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="IsExpanded" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TreeViewItem">
                        <StackPanel>
                            <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                    Padding="{TemplateBinding Padding}"
                                    BorderBrush="#2a2a2a" BorderThickness="0,0,0,1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <ToggleButton x:Name="Expander" Grid.Column="0"
                                                  IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}"
                                                  ClickMode="Press" Focusable="False" Cursor="Hand"
                                                  VerticalAlignment="Center">
                                        <ToggleButton.Template>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <Border Background="Transparent" Width="20" Height="20">
                                                    <TextBlock x:Name="Glyph" Text="&#xE76C;" Foreground="#666"
                                                               FontFamily="Segoe MDL2 Assets" FontSize="10"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsChecked" Value="True">
                                                        <Setter TargetName="Glyph" Property="Text" Value="&#xE70D;"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </ToggleButton.Template>
                                    </ToggleButton>
                                    <ContentPresenter Grid.Column="1" ContentSource="Header"/>
                                </Grid>
                            </Border>
                            <ItemsPresenter x:Name="ItemsHost" Margin="20,0,0,0"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="HasItems" Value="False">
                                <Setter TargetName="Expander" Property="Visibility" Value="Hidden"/>
                            </Trigger>
                            <Trigger Property="IsExpanded" Value="False">
                                <Setter TargetName="ItemsHost" Property="Visibility" Value="Collapsed"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#252525"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Repo row template -->
        <HierarchicalDataTemplate DataType="{x:Type models:RepoNode}" ItemsSource="{Binding WorktreesView}">
            <Border BorderThickness="5,0,0,0" Padding="2,0,0,0"
                    BorderBrush="{Binding AgentState, Converter={StaticResource AgentBrush}, ConverterParameter=accent}"
                    Background="{Binding AgentState, Converter={StaticResource AgentBrush}}">
                <Grid Height="32" MouseLeftButtonDown="OnRowMouseDown">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" MinWidth="160"/>
                        <ColumnDefinition Width="1.2*" MinWidth="100"/>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="{Binding AgentState, Converter={StaticResource AgentGlyph}}"
                                   FontFamily="Segoe MDL2 Assets" FontSize="11"
                                   Foreground="{Binding AgentState, Converter={StaticResource AgentBrush}, ConverterParameter=accent}"
                                   VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBlock Text="{Binding Name}" Foreground="#e8e8e8"
                                   FontSize="13" FontFamily="Segoe UI Semibold"
                                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                        <Border Background="#22000000" CornerRadius="2"
                                Padding="4,0" Margin="6,0,0,0"
                                Visibility="{Binding AgentSessionCount, Converter={StaticResource GtOneToVis}}">
                            <TextBlock Foreground="#e8e8e8" FontSize="10" FontFamily="Segoe UI"
                                       VerticalAlignment="Center"
                                       Text="{Binding AgentSessionCount, StringFormat=×{0}}"/>
                        </Border>
                    </StackPanel>
                    <TextBlock Grid.Column="1" Text="{Binding Branch}" Foreground="#9cdcfe"
                               FontSize="12" FontFamily="Consolas"
                               VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                    <TextBlock Grid.Column="2" Text="{Binding LastActivityUtc, Converter={StaticResource RelativeTime}}"
                               Foreground="#888" FontSize="11" FontFamily="Segoe UI"
                               VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0,4,0">
                        <Button Content="&#xE8A7;" Click="OnOpenClick" Tag="{Binding}"
                                Style="{StaticResource RowActionButtonStyle}" ToolTip="Open in ai-frame"/>
                        <Button Content="&#xE710;" Click="OnNewWorktreeClick" Tag="{Binding}"
                                Style="{StaticResource RowActionButtonStyle}" ToolTip="Create new worktree…"/>
                    </StackPanel>
                </Grid>
            </Border>
        </HierarchicalDataTemplate>

        <!-- Worktree row template -->
        <DataTemplate DataType="{x:Type models:WorktreeNode}">
            <Border BorderThickness="5,0,0,0" Padding="2,0,0,0"
                    BorderBrush="{Binding AgentState, Converter={StaticResource AgentBrush}, ConverterParameter=accent}"
                    Background="{Binding AgentState, Converter={StaticResource AgentBrush}}">
                <Grid Height="28" MouseLeftButtonDown="OnRowMouseDown">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" MinWidth="160"/>
                        <ColumnDefinition Width="1.2*" MinWidth="100"/>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="{Binding AgentState, Converter={StaticResource AgentGlyph}}"
                                   FontFamily="Segoe MDL2 Assets" FontSize="10"
                                   Foreground="{Binding AgentState, Converter={StaticResource AgentBrush}, ConverterParameter=accent}"
                                   VerticalAlignment="Center" Margin="0,0,2,0"/>
                        <TextBlock Text="&#xE8AD;" Foreground="#666" FontFamily="Segoe MDL2 Assets"
                                   FontSize="10" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding DisplayName}" Foreground="#cfcfcf"
                                   FontSize="12" FontFamily="Segoe UI"
                                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                        <TextBlock Text="{Binding FolderLabel}" Foreground="#555"
                                   FontSize="10" FontFamily="Consolas"
                                   VerticalAlignment="Center" Margin="6,0,0,0"/>
                        <Border Background="#22000000" CornerRadius="2"
                                Padding="4,0" Margin="6,0,0,0"
                                Visibility="{Binding AgentSessionCount, Converter={StaticResource GtOneToVis}}">
                            <TextBlock Foreground="#e8e8e8" FontSize="10" FontFamily="Segoe UI"
                                       VerticalAlignment="Center"
                                       Text="{Binding AgentSessionCount, StringFormat=×{0}}"/>
                        </Border>
                    </StackPanel>
                    <TextBlock Grid.Column="1" Text="{Binding Branch}" Foreground="#9cdcfe"
                               FontSize="11" FontFamily="Consolas"
                               VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                    <TextBlock Grid.Column="2" Text="{Binding LastActivityUtc, Converter={StaticResource RelativeTime}}"
                               Foreground="#777" FontSize="11" FontFamily="Segoe UI"
                               VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0,4,0">
                        <Button Content="&#xE8A7;" Click="OnOpenClick" Tag="{Binding}"
                                Style="{StaticResource RowActionButtonStyle}" ToolTip="Open in ai-frame"/>
                        <Button Content="&#xE72C;" Click="OnResetWorktreeClick" Tag="{Binding}"
                                Style="{StaticResource RowActionButtonStyle}" ToolTip="Reset worktree…"/>
                        <Button Content="&#xE74D;" Click="OnDeleteWorktreeClick" Tag="{Binding}"
                                Style="{StaticResource RowActionButtonStyle}" ToolTip="Delete worktree…"/>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Border BorderBrush="#5a5a5a" BorderThickness="1" CornerRadius="8">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title bar -->
        <Border Grid.Row="0" Background="#252525">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Grid Width="200" Height="22" Margin="0,0,8,0" VerticalAlignment="Center">
                        <TextBox x:Name="FilterBox"
                                 Background="#1c1c1c" Foreground="#e8e8e8" BorderBrush="#383838"
                                 BorderThickness="1" Padding="22,1,6,1"
                                 CaretBrush="#e8e8e8" SelectionBrush="#0078d4"
                                 FontFamily="Segoe UI" FontSize="11"
                                 VerticalContentAlignment="Center"
                                 TextChanged="OnFilterTextChanged"/>
                        <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                   Foreground="#666" VerticalAlignment="Center"
                                   HorizontalAlignment="Left" Margin="6,0,0,0"
                                   IsHitTestVisible="False"/>
                        <TextBlock x:Name="FilterPlaceholder" Text="Filter (Ctrl+F)"
                                   Foreground="#555" VerticalAlignment="Center"
                                   HorizontalAlignment="Left" Margin="24,0,0,0"
                                   FontSize="11" FontFamily="Segoe UI"
                                   IsHitTestVisible="False"/>
                    </Grid>
                    <Button Content="&#xE72C;" Click="OnRefreshClick"
                            Style="{StaticResource CaptionButtonStyle}" ToolTip="Refresh (Ctrl+R)"
                            FontSize="14"/>
                    <Button Content="&#xE8DA;" Click="OnPickRootClick"
                            Style="{StaticResource CaptionButtonStyle}" ToolTip="Change root folder"
                            FontSize="14"/>
                    <Button Content="&#xE713;" Click="OnSettingsClick"
                            Style="{StaticResource CaptionButtonStyle}" ToolTip="Settings"
                            FontSize="14"/>
                    <Border Width="1" Background="#383838" Margin="0,6"/>
                    <Button Content="&#xE921;" Click="OnMinimizeClick"
                            Style="{StaticResource CaptionButtonStyle}" ToolTip="Minimize"/>
                    <Button x:Name="MaximizeButton" Content="&#xE922;" Click="OnMaximizeClick"
                            Style="{StaticResource CaptionButtonStyle}" ToolTip="Maximize"/>
                    <Button Content="&#xE8BB;" Click="OnCloseClick"
                            Style="{StaticResource CloseButtonStyle}" ToolTip="Close"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0,0,0">
                    <TextBlock Text="ai-stage" Foreground="#e8e8e8" FontSize="12"
                               FontFamily="Segoe UI Semibold"
                               VerticalAlignment="Center"/>
                    <TextBlock x:Name="VersionText" Text="" Foreground="#666"
                               FontSize="11" FontFamily="Segoe UI"
                               FontStyle="Italic"
                               VerticalAlignment="Center" Margin="6,0,0,0"/>
                </StackPanel>
                <TextBlock x:Name="RootPathText" Text="" Foreground="#666"
                           VerticalAlignment="Center" HorizontalAlignment="Center"
                           FontSize="11" FontFamily="Segoe UI"
                           TextTrimming="CharacterEllipsis"/>
            </DockPanel>
        </Border>

        <!-- Column header -->
        <Border Grid.Row="1" Background="#1a1a1a" BorderBrush="#2a2a2a" BorderThickness="0,0,0,1">
            <Grid Margin="20,0,0,0" Height="28">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" MinWidth="160"/>
                    <ColumnDefinition Width="1.2*" MinWidth="100"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="Auto" MinWidth="120"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Repository" Foreground="#666"
                           FontSize="11" FontFamily="Segoe UI" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" Text="Branch" Foreground="#666"
                           FontSize="11" FontFamily="Segoe UI" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="2" Text="Last activity" Foreground="#666"
                           FontSize="11" FontFamily="Segoe UI" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Body -->
        <Grid Grid.Row="2">
            <TreeView x:Name="RepoTree"
                      Background="Transparent" BorderThickness="0"
                      Foreground="#e8e8e8"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                      ItemContainerStyle="{StaticResource StageTreeViewItemStyle}"/>

            <!-- Empty / status overlay -->
            <StackPanel x:Name="EmptyState" Visibility="Collapsed"
                        HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock x:Name="EmptyStateText" Text="No git repositories found."
                           Foreground="#888" FontSize="14" FontFamily="Segoe UI"
                           HorizontalAlignment="Center"/>
                <Button Content="Change root folder…" Click="OnPickRootClick"
                        Background="#0078d4" Foreground="White" BorderThickness="0"
                        Padding="16,6" FontSize="12" FontFamily="Segoe UI"
                        Cursor="Hand" Margin="0,12,0,0" HorizontalAlignment="Center"/>
            </StackPanel>

            <TextBlock x:Name="ScanningText" Text="Scanning…"
                       Foreground="#666" FontSize="13" FontFamily="Segoe UI"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Visibility="Collapsed"/>

            <!-- Busy overlay (modal spinner + message) -->
            <Grid x:Name="BusyOverlay" Background="#C0000000" Visibility="Collapsed" Panel.ZIndex="100">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Grid Width="44" Height="44" HorizontalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                        <Grid.RenderTransform>
                            <RotateTransform/>
                        </Grid.RenderTransform>
                        <Grid.Triggers>
                            <EventTrigger RoutedEvent="Grid.Loaded">
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever">
                                        <DoubleAnimation Storyboard.TargetProperty="(Grid.RenderTransform).(RotateTransform.Angle)"
                                                         From="0" To="360" Duration="0:0:1"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Grid.Triggers>
                        <Path Stroke="#0078d4" StrokeThickness="3" StrokeStartLineCap="Round" StrokeEndLineCap="Round">
                            <Path.Data>
                                <PathGeometry>
                                    <PathFigure StartPoint="40,22">
                                        <ArcSegment Point="22,4" Size="18,18"
                                                    SweepDirection="Counterclockwise" IsLargeArc="True"/>
                                    </PathFigure>
                                </PathGeometry>
                            </Path.Data>
                        </Path>
                    </Grid>
                    <TextBlock x:Name="BusyText" Foreground="#e8e8e8" FontSize="13" FontFamily="Segoe UI"
                               HorizontalAlignment="Center" Margin="0,18,0,0"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
    </Border>
</Window>
