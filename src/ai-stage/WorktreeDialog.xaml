<Window x:Class="AiStage.WorktreeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="ai-stage — New worktree"
        Width="520" Height="320"
        MinWidth="440" MinHeight="240"
        Background="#1e1e1e"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        WindowStyle="None"
        AllowsTransparency="False"
        KeyDown="OnKeyDown">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome
            CaptionHeight="32"
            GlassFrameThickness="0"
            CornerRadius="0"
            ResizeBorderThickness="6"
            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <Style x:Key="DialogCloseButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#999"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="Transparent">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#e81123"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#2a2a2a"/>
            <Setter Property="Foreground" Value="#e8e8e8"/>
            <Setter Property="BorderBrush" Value="#444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CaretBrush" Value="#e8e8e8"/>
            <Setter Property="SelectionBrush" Value="#0078d4"/>
        </Style>
    </Window.Resources>

    <Border BorderBrush="#5a5a5a" BorderThickness="1" CornerRadius="8">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#252525">
            <DockPanel>
                <Button Content="&#xE8BB;" DockPanel.Dock="Right" Click="OnCancelClick"
                        Style="{StaticResource DialogCloseButtonStyle}"
                        shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
                <TextBlock x:Name="TitleText" Text="New worktree" Foreground="#888"
                           FontSize="12" FontFamily="Segoe UI"
                           VerticalAlignment="Center" Margin="14,0,0,0"/>
            </DockPanel>
        </Border>

        <StackPanel Grid.Row="1" Margin="20,16,20,0">
            <!-- Mode picker (visible only in Reset mode) -->
            <StackPanel x:Name="ModePanel" Orientation="Horizontal" Margin="0,0,0,10" Visibility="Collapsed">
                <RadioButton x:Name="ModeNewBranchRadio" Content="New branch" GroupName="ResetMode"
                             Foreground="#ddd" FontSize="12" FontFamily="Segoe UI"
                             IsChecked="True" Checked="OnModeChanged" Margin="0,0,16,0"/>
                <RadioButton x:Name="ModeExistingBranchRadio" Content="Existing branch" GroupName="ResetMode"
                             Foreground="#ddd" FontSize="12" FontFamily="Segoe UI"
                             Checked="OnModeChanged" Margin="0,0,16,0"/>
                <RadioButton x:Name="ModeDefaultBranchRadio" Content="Default branch" GroupName="ResetMode"
                             Foreground="#ddd" FontSize="12" FontFamily="Segoe UI"
                             Checked="OnModeChanged"/>
            </StackPanel>

            <!-- New-branch input -->
            <StackPanel x:Name="NewBranchPanel">
                <TextBlock Text="Branch name" Foreground="#aaa" FontSize="11" FontFamily="Segoe UI"/>
                <TextBox x:Name="NameBox" Style="{StaticResource DarkTextBoxStyle}" Margin="0,4,0,0"/>
            </StackPanel>

            <!-- Existing-branch picker -->
            <StackPanel x:Name="ExistingBranchPanel" Visibility="Collapsed">
                <TextBlock Text="Existing remote branch" Foreground="#aaa" FontSize="11" FontFamily="Segoe UI"/>
                <Grid Margin="0,4,0,0">
                    <ComboBox x:Name="ExistingBranchCombo" IsEditable="True"
                              Background="#2a2a2a" Foreground="#e8e8e8" BorderBrush="#444"
                              FontFamily="Segoe UI" FontSize="13" Padding="6,4"
                              SelectionChanged="OnExistingBranchChanged"
                              KeyUp="OnExistingBranchTextChanged"/>
                    <TextBlock x:Name="ExistingBranchLoadingText" Text="Fetching…"
                               Foreground="#888" FontSize="11" FontFamily="Segoe UI"
                               HorizontalAlignment="Right" VerticalAlignment="Center"
                               Margin="0,0,28,0" Visibility="Collapsed" IsHitTestVisible="False"/>
                </Grid>
            </StackPanel>

            <!-- Default-branch display -->
            <StackPanel x:Name="DefaultBranchPanel" Visibility="Collapsed">
                <TextBlock Text="Default branch" Foreground="#aaa" FontSize="11" FontFamily="Segoe UI"/>
                <Border Background="#2a2a2a" BorderBrush="#444" BorderThickness="1"
                        Padding="8,6" Margin="0,4,0,0">
                    <TextBlock x:Name="DefaultBranchText" Text="" Foreground="#e8e8e8"
                               FontSize="13" FontFamily="Consolas, Cascadia Mono, Segoe UI"/>
                </Border>
            </StackPanel>

            <TextBlock x:Name="PathHintText" Text="" Foreground="#666" FontSize="11"
                       FontFamily="Segoe UI" Margin="0,8,0,0" TextTrimming="CharacterEllipsis"/>
        </StackPanel>

        <Border Grid.Row="2" Background="#252525" Padding="20,10">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Content="Cancel" Click="OnCancelClick"
                            Background="#333" Foreground="#ccc" BorderThickness="0"
                            Padding="16,6" FontSize="12" FontFamily="Segoe UI"
                            Cursor="Hand" Margin="0,0,8,0"/>
                    <Button x:Name="CreateButton" Content="Create" Click="OnCreateClick" IsDefault="True"
                            Background="#0078d4" Foreground="White" BorderThickness="0"
                            Padding="16,6" FontSize="12" FontFamily="Segoe UI Semibold"
                            Cursor="Hand"/>
                </StackPanel>
                <TextBlock Text="Enter to confirm" Foreground="#555"
                           FontSize="11" FontFamily="Segoe UI" VerticalAlignment="Center"/>
            </DockPanel>
        </Border>
    </Grid>
    </Border>
</Window>
