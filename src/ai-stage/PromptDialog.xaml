<Window x:Class="AiStage.PromptDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="ai-stage — Open with prompt"
        Width="560" Height="360"
        MinWidth="420" MinHeight="280"
        Background="#1e1e1e"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        WindowStyle="None"
        AllowsTransparency="False"
        KeyDown="OnKeyDown">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome
            CaptionHeight="32"
            GlassFrameThickness="0"
            CornerRadius="0"
            ResizeBorderThickness="6"
            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <Style x:Key="DialogCloseButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#999"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="Transparent">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#e81123"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#252525">
            <DockPanel>
                <Button Content="&#xE8BB;" DockPanel.Dock="Right" Click="OnCancelClick"
                        Style="{StaticResource DialogCloseButtonStyle}"
                        shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
                <TextBlock x:Name="TitleText" Text="Open with initial prompt" Foreground="#888"
                           FontSize="12" FontFamily="Segoe UI"
                           VerticalAlignment="Center" Margin="14,0,0,0"/>
            </DockPanel>
        </Border>

        <StackPanel Grid.Row="1" Margin="20,16,20,0">
            <TextBlock Text="Initial prompt" Foreground="#aaa" FontSize="11" FontFamily="Segoe UI"/>
            <TextBlock Text="Sent to Copilot when ai-frame starts. Leave blank to cancel."
                       Foreground="#666" FontSize="10" FontFamily="Segoe UI" Margin="0,2,0,4"/>
            <TextBox x:Name="PromptBox" Background="#2a2a2a" Foreground="#e8e8e8"
                     BorderBrush="#444" BorderThickness="1" Padding="8,6"
                     FontFamily="Segoe UI" FontSize="13"
                     CaretBrush="#e8e8e8" SelectionBrush="#0078d4"
                     Height="180" TextWrapping="Wrap" AcceptsReturn="True"
                     VerticalScrollBarVisibility="Auto"/>
        </StackPanel>

        <Border Grid.Row="2" Background="#252525" Padding="20,10">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Content="Cancel" Click="OnCancelClick"
                            Background="#333" Foreground="#ccc" BorderThickness="0"
                            Padding="16,6" FontSize="12" FontFamily="Segoe UI"
                            Cursor="Hand" Margin="0,0,8,0"/>
                    <Button Content="Open" Click="OnOpenClick" IsDefault="True"
                            Background="#0078d4" Foreground="White" BorderThickness="0"
                            Padding="16,6" FontSize="12" FontFamily="Segoe UI Semibold"
                            Cursor="Hand"/>
                </StackPanel>
                <TextBlock Text="Ctrl+Enter to open" Foreground="#555"
                           FontSize="11" FontFamily="Segoe UI" VerticalAlignment="Center"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
