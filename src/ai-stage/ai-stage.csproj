<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows</TargetFramework>
    <UseWPF>true</UseWPF>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <AssemblyName>ai-stage</AssemblyName>
    <RootNamespace>AiStage</RootNamespace>
    <ApplicationIcon>app.ico</ApplicationIcon>
    <!--
      We supply our own Main in Program.cs so VelopackApp.Build().Run()
      can execute before any WPF types are loaded. Suppress the WPF SDK's
      auto-generated entry point and point StartupObject at ours.
    -->
    <StartupObject>AiStage.Program</StartupObject>
  </PropertyGroup>

  <ItemGroup>
    <!--
      Demote App.xaml from ApplicationDefinition to Page so the SDK
      doesn't auto-generate a Main that bypasses Program.Main.
    -->
    <ApplicationDefinition Remove="App.xaml" />
    <Page Include="App.xaml" />
  </ItemGroup>

  <ItemGroup>
    <Resource Include="Resources\app-icon.png" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Velopack" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\AgentSessions\AgentSessions.csproj" />
    <ProjectReference Include="..\ai-frame\ai-frame.csproj">
      <ReferenceOutputAssembly>false</ReferenceOutputAssembly>
      <Private>false</Private>
    </ProjectReference>
  </ItemGroup>

  <Target Name="CopyFrameToOutput" AfterTargets="Build">
    <ItemGroup>
      <_FrameFiles Include="$(MSBuildThisFileDirectory)..\ai-frame\bin\$(Configuration)\$(TargetFramework)\**\*.*" />
    </ItemGroup>
    <Copy
        SourceFiles="@(_FrameFiles)"
        DestinationFiles="@(_FrameFiles->'$(OutDir)%(RecursiveDir)%(Filename)%(Extension)')"
        SkipUnchangedFiles="true"
        Condition="'@(_FrameFiles)' != ''" />
  </Target>

</Project>
